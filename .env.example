# Port to expose the app on (default: 6767)
PORT=6767

# Google OAuth — create credentials at console.cloud.google.com
# OAuth type: Web application
# Authorized redirect URI: http://localhost:6767/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Random secret for signing session cookies (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change-me

# Public base URL of the app (used to build the OAuth redirect URI)
BASE_URL=http://localhost:6767
